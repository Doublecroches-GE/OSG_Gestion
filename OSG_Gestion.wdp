      EXTERN "KeyConst.wl"
      EXTERN "WINCONST.WL"
      
      gcl_SessionEnCours	est une CL_Session
      gcl_Impression		est une CL_Impression
      gs_utilisateur		est une chaîne
      gn_numtimer			est un entier
      gtab_typeSeance		est un tableau associatif de chaines
      gn_connexion		est une connexion
      
      gtab_Instruments	est un tableau de CL_Instrument
      
      SET_Connexion()
      //HCréationSiInexistant(Repetition_Session_Pupitre)
      
      gs_utilisateur = INILit("Utilisateurs", "Administrateur", "", fRepExe() + "\Param.ini" )
      
      SI ErreurDétectée ALORS
      	Erreur("Attention, le fichier de démarrage est absent, merci de contacter le support." + RC + "Le programme va se fermer.")
      	FinProgramme()
      FIN
      
      Charger_Instruments()
      Charger_TypeSeance()
      GET_SessionEnCours()
